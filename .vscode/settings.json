{
  // ---------------------------------------------------------------------------
  // Editor-only performance settings for low-memory clients (e.g. opening this
  // Codespace in an iPad browser tab). These ONLY change how the VS Code editor
  // behaves. They do NOT affect the app, the build (EAS / GitHub Actions), the
  // dependencies, or any source code. `node_modules` is auto-generated by
  // `npm install` and is never part of your code — the editor has no reason to
  // watch or index all of it. Safe to delete this file at any time to revert.
  // ---------------------------------------------------------------------------

  // Stop the file watcher from streaming change events for thousands of
  // node_modules files to the browser (the #1 cause of the iPad tab freezing).
  "files.watcherExclude": {
    "**/node_modules/**": true,
    "**/.expo/**": true,
    "**/.git/objects/**": true,
    "**/dist/**": true,
    "**/build/**": true,
    "**/android/**": true,
    "**/ios/**": true
  },

  // Keep node_modules and lockfiles out of search results (faster, lighter).
  "search.exclude": {
    "**/node_modules": true,
    "**/.expo": true,
    "**/package-lock.json": true,
    "**/pnpm-lock.yaml": true,
    "**/dist": true
  },

  // Don't auto-download extra @types packages in the background.
  "typescript.disableAutomaticTypeAcquisition": true,

  // Give the (cloud-side) TypeScript server more headroom so it doesn't thrash.
  "typescript.tsserver.maxTsServerMemory": 3072,

  // Reduce background chatter that the iPad tab has to render/process.
  "npm.autoDetect": "off",
  "git.autorefresh": false,
  "git.autofetch": false,
  "telemetry.telemetryLevel": "off"
}
