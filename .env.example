# Example environment variables for local development
# Copy this file to `.env` and fill with real values.

# Supabase public URL and anon key
EXPO_PUBLIC_SUPABASE_URL=
EXPO_PUBLIC_SUPABASE_ANON_KEY=

# OpenAI key used by Supabase Edge function (optional for local dev)
OPENAI_API_KEY=

# Expo token for CI (optional; set as GitHub secret)
EXPO_TOKEN=

# Any other secrets referenced in docs (add as needed)
# EAS variables can be set in expo.dev via `eas env:create`
